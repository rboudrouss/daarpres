---
import Slide from "../components/Slide.astro";
---

<Slide>
	<h2>Structure de la population</h2>
	<p class="muted" style="margin-bottom: 0.6em">
		Chaque <span class="highlight">lion = une solution candidate</span> dans l'espace de recherche
	</p>
	<div class="pop-diagram">
		<div class="pride-box">
			<div class="box-title">Fierté 1</div>
			<div class="lion-icon">🦁🦁</div>
			<div style="color: #ccc; margin-top: 0.3em">♀ ♀ ♀ ♂</div>
			<div class="pop-label">~80% femelles</div>
		</div>
		<div class="pride-box">
			<div class="box-title">Fierté 2</div>
			<div class="lion-icon">🦁🦁</div>
			<div style="color: #ccc; margin-top: 0.3em">♀ ♀ ♀ ♂</div>
			<div class="pop-label">~80% femelles</div>
		</div>
		<div class="pride-box">
			<div class="box-title">Fierté P</div>
			<div class="lion-icon">🦁🦁</div>
			<div style="color: #ccc; margin-top: 0.3em">♀ ♀ ♀ ♂</div>
			<div class="pop-label">~80% femelles</div>
		</div>
		<div class="nomad-box">
			<div class="box-title">Nomades</div>
			<div class="lion-icon">🦁</div>
			<div style="color: #ccc; margin-top: 0.3em">♂ ♂ ♀</div>
			<div class="pop-label">~20% pop · ~80% mâles</div>
		</div>
	</div>
	<div style="font-size: 0.68em; color: #aaa; margin-top: 0.6em; text-align: center">
		Territoire d'une fierté = ensemble des
		<span class="highlight">meilleures positions visitées</span> par ses membres
	</div>
</Slide>
